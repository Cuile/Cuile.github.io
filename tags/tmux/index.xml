&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>tmux split-window -h -t &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>MY_SESSION&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span>:0.3
