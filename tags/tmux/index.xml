&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#75715e"># 使用select-layout更方便&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>tmux &lt;span style="color:#66d9ef">select&lt;/span>-layout -t &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>MY_SESSION&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span> &lt;span style="color:#e6db74">&amp;#39;9a1d,267x50,0,0[267x9,0,0,17,267x9,0,10,19,267x9,0,20,18,267x20,0,30{134x20,0,30,20,132x20,135,30,21}]&amp;#39;&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#75715e"># 给面板命名&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>tmux &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;1step&amp;#34;&lt;/span> -t &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>MY_SESSION&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span>:0.0
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>tmux &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;2step&amp;#34;&lt;/span> -t &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>MY_SESSION&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span>:0.1
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>tmux &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;check&amp;#34;&lt;/span> -t &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>MY_SESSION&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span>:0.2
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>tmux &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;submit&amp;#34;&lt;/span> -t &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>MY_SESSION&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span>:0.3
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#75715e"># 面板执行命令&lt;/span>
