&lt;h3 id="会话操作">会话操作&lt;/h3>
&lt;table>
 &lt;thead>
 &lt;tr>
 &lt;th style="text-align: center">操作&lt;/th>
 &lt;th style="text-align: center">快捷键&lt;/th>
 &lt;th style="text-align: left">命令&lt;/th>
 &lt;th style="text-align: left">备注&lt;/th>
 &lt;/tr>
 &lt;/thead>
 &lt;tbody>
 &lt;tr>
 &lt;td style="text-align: center">启动会话&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>tmux new -s &amp;lt;session_name&amp;gt;&lt;/code>&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">进入会话&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>tmux &amp;lt;attach | a&amp;gt; -t &amp;lt;session_name | session_index&amp;gt;&lt;/code>&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">退出会话&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , d&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;code>detach&lt;/code>&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">关闭会话&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>tmux kill-session -t &amp;lt;session_name | session_index&amp;gt;&lt;/code>&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">&lt;strong>命令模式&lt;/strong>&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , :&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">会话列表&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>list-session&lt;/code>&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">跳转会话&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , s&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;code>switch -t &amp;lt;session_name | session_index&amp;gt;&lt;/code>&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">重命名会话&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , $&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;code>rename-session -t &amp;lt;old_name | session_index&amp;gt; &amp;lt;new_name&amp;gt;&lt;/code>&lt;/td>
 &lt;td>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">翻屏模式&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , [&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;td style="text-align: left">PgUp, PgDn 实现上下翻页（mac可以用 fn + ↑ ↓实现上下翻页）&lt;!-- raw HTML omitted --> q 退出翻屏模式&lt;/td>
 &lt;/tr>
 &lt;/tbody>
&lt;/table>
&lt;h3 id="窗口操作">窗口操作&lt;/h3>
&lt;table>
 &lt;thead>
 &lt;tr>
 &lt;th style="text-align: center">操作&lt;/th>
 &lt;th style="text-align: center">快捷键&lt;/th>
 &lt;th style="text-align: left">命令&lt;/th>
 &lt;/tr>
 &lt;/thead>
 &lt;tbody>
 &lt;tr>
 &lt;td style="text-align: center">窗口列表&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>list-window [-t &amp;lt;session_name&amp;gt;]&lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">在当前会话添加一个窗口&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , c&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">在当前会话的多个窗口中选择&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , w&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">关闭当前会话的当前窗口&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , x&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">关闭当前会话的所有窗口&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , !&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">关闭会话窗口&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>kill-window -t &amp;lt;session_name | session_index&amp;gt;:&amp;lt;window-index&amp;gt;&lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">切换窗口顺序&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , 数字键&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">窗口导航&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , &amp;lt; n | p &amp;gt;&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;/tbody>
&lt;/table>
&lt;h3 id="面板操作">面板操作&lt;/h3>
&lt;table>
 &lt;thead>
 &lt;tr>
 &lt;th style="text-align: center">操作&lt;/th>
 &lt;th style="text-align: center">快捷键&lt;/th>
 &lt;th style="text-align: left">命令&lt;/th>
 &lt;/tr>
 &lt;/thead>
 &lt;tbody>
 &lt;tr>
 &lt;td style="text-align: center">面板列表&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>list-panes -t &amp;lt;session_name | session_index&amp;gt;:&amp;lt;window-index&amp;gt;&lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">修改面板标题&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>select-pane -T &amp;quot;new-title&amp;quot; -t &amp;lt;session-name&amp;gt;:&amp;lt;window-index&amp;gt;.&amp;lt;pane-index&amp;gt;&lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">展示面板编号&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , q&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">面板移动到窗口&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>move-pane -t &amp;lt;session-name&amp;gt;:&amp;lt;window-index&amp;gt;&lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">将当前窗口分成左右两份&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , %&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">将当前窗口分成上下两份&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix ，&amp;quot;&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">水平排列改为垂直排列&lt;/td>
 &lt;td style="text-align: center">&lt;code>按住 Prefix , -&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">垂直排列改为水平排列&lt;/td>
 &lt;td style="text-align: center">&lt;code>按住 Prefix , \&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">所有面板水平排列&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>select-layout even-horizontal &lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">所有面板垂直排列&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>select-layout even-verticalc&lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">所有面板位置顺时针轮换&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , Ctrl + o&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">所有面板位置逆时针轮换&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , Alt + o&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">当前面板与左侧/上方面板交换&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , {&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">当前面板与右侧/下方面板交换&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , }&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">交换面板&lt;/td>
 &lt;td style="text-align: center">&lt;/td>
 &lt;td style="text-align: left">&lt;code>swap-pane -s &amp;lt;source-pane-index&amp;gt; -t &amp;lt;target-pane-index&amp;gt;&lt;/code>&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">切换当前面板的布局方向&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , Space&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">循环切换 5 种预设布局&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , Alt + [1~5]&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">关闭当前面板&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , x&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">光标在不同的窗口中跳转&lt;/td>
 &lt;td style="text-align: center">&lt;code>Prefix , &amp;lt; ↑ | ↓ | ← | → &amp;gt;&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: center">调节光标所在窗口的大小&lt;/td>
 &lt;td style="text-align: center">&lt;code>按住 Prefix , &amp;lt; ↑ | ↓ | ← | → &amp;gt;&lt;/code>&lt;/td>
 &lt;td style="text-align: left">&lt;/td>
 &lt;/tr>
 &lt;/tbody>
&lt;/table>
&lt;h2 id="脚本操作">脚本操作&lt;/h2>
&lt;h3 id="tmux格式">Tmux格式&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-bash" data-lang="bash">&lt;span style="display:flex;">&lt;span>tmux new-session -s &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>MY_SESSION&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span> -d &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> split-window -v &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> split-window -v -t &lt;span style="color:#ae81ff">0&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> split-window -v -t &lt;span style="color:#ae81ff">2&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> split-window -h -t &lt;span style="color:#ae81ff">3&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> &lt;span style="color:#66d9ef">select&lt;/span>-layout &lt;span style="color:#e6db74">&amp;#39;e1ef,267x50,0,0[267x9,0,0,0,267x9,0,10,2,267x9,0,20,1,267x20,0,30{153x20,0,30,3,113x20,154,30,4}]&amp;#39;&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;1step&amp;#34;&lt;/span> -t &lt;span style="color:#ae81ff">0&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;2step&amp;#34;&lt;/span> -t &lt;span style="color:#ae81ff">1&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;check&amp;#34;&lt;/span> -t &lt;span style="color:#ae81ff">2&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;submit&amp;#34;&lt;/span> -t &lt;span style="color:#ae81ff">3&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> &lt;span style="color:#66d9ef">select&lt;/span>-pane -T &lt;span style="color:#e6db74">&amp;#34;check submitable&amp;#34;&lt;/span> -t &lt;span style="color:#ae81ff">4&lt;/span> &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> send-keys -t &lt;span style="color:#ae81ff">0&lt;/span> &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>ACTIVATE&lt;span style="color:#e6db74">}${&lt;/span>COMMAND_1STEP&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span> Enter &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> send-keys -t &lt;span style="color:#ae81ff">1&lt;/span> &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>ACTIVATE&lt;span style="color:#e6db74">}${&lt;/span>COMMAND_2STEP&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span> Enter &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ae81ff">&lt;/span> send-keys -t &lt;span style="color:#ae81ff">2&lt;/span> &lt;span style="color:#e6db74">&amp;#34;&lt;/span>&lt;span style="color:#e6db74">${&lt;/span>ACTIVATE&lt;span style="color:#e6db74">}${&lt;/span>COMMAND_CHECK&lt;span style="color:#e6db74">}&lt;/span>&lt;span style="color:#e6db74">&amp;#34;&lt;/span> Enter &lt;span style="color:#ae81ff">\;&lt;/span> &lt;span style="color:#ae81ff">\
